VITE_API_URL=http://localhost:8180

# Meta Pixel (public — embedded in the browser bundle)
VITE_META_PIXEL_ID=
# Set to "true" to disable pixel scripts and tracking calls in dev
# VITE_META_PIXEL_DISABLED=true

# Google Analytics 4 (public — embedded in the browser bundle)
VITE_GA4_MEASUREMENT_ID=
# Set to "true" to disable gtag scripts and client page_view calls in dev
# VITE_GA4_DISABLED=true

# Purchase events for Meta Conversions API are sent by the Go API (serverside) when an order
# is created — see serverside/.env.example (META_PIXEL_ID, META_ACCESS_TOKEN).
